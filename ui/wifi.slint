import { ScrollView, LineEdit, Button, CheckBox } from "std-widgets.slint";

export struct VpnItem {
    name: string,
    active: bool,
    type_name: string,
}

export struct NetworkItem {
    ssid: string,
    signal: int,
    security: string,
    connected: bool,
    saved: bool,
    ping: string,
    icon: string,
    icon_color: color,
}
export global Palette {
    in-out property <color> background: #09090b88; // 50% opacity for glassmorphism
    in-out property <color> card-bg: #18181b;
    in-out property <color> accent: #00f0ff;
    in-out property <color> foreground: #f8fafc;
    in-out property <color> secondary-fg: #a1a1aa;
    in-out property <color> separator: #27272a;
}

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: true;
    in property <bool> enabled: true;
    in property <bool> danger: false;
    callback clicked;
    
    height: 28px;
    background: primary ? (enabled ? Palette.accent : Palette.accent.with-alpha(0.3)) : transparent;
    border-radius: 4px;
    border-width: 1px;
    border-color: danger ? #ff0055.with-alpha(0.8) : Palette.accent.with-alpha(0.8);
    
    states [
        hover when touch.has-hover && enabled : {
            background: primary ? Palette.accent.brighter(20%) : (danger ? #ff0055.with-alpha(0.2) : Palette.accent.with-alpha(0.2));
        }
        pressed when touch.pressed && enabled : {
            background: primary ? Palette.accent.darker(20%) : (danger ? #ff0055.with-alpha(0.4) : Palette.accent.with-alpha(0.4));
        }
    ]

    touch := TouchArea {
        clicked => { if (enabled) { root.clicked(); } }
    }

    Text {
        text: root.text;
        color: primary ? Palette.background : (danger ? #ff0055 : Palette.accent);
        font-size: 10px;
        font-weight: 900;
        letter-spacing: 1.5px;
    }
}

component ThemeToggle inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked;
    callback toggled(bool);

    height: 28px;
    
    HorizontalLayout {
        spacing: 12px;
        alignment: start;
        
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 20px;
                background: root.checked ? Palette.accent : Palette.foreground.with-alpha(0.1);
                border-radius: 10px;
                
                Rectangle {
                    x: root.checked ? 22px : 2px;
                    y: 2px;
                    width: 16px;
                    height: 16px;
                    background: white;
                    border-radius: 8px;
                    animate x { duration: 250ms; easing: ease-in-out; }
                }
            }
        }
        
        if (root.text != "") : Text {
            text: root.text;
            color: Palette.foreground;
            font-size: 13px;
            font-weight: 500;
            vertical-alignment: center;
        }
    }
    
    TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

component SpeedGraph inherits Rectangle {
    in property <[float]> download_points;
    in property <[float]> upload_points;
    in property <float> max_val;
    
    background: Palette.card-bg.darker(30%);
    border-radius: 12px;
    clip: true;

    for p[i] in download_points : Rectangle {
        x: (60 - download_points.length + i) * (parent.width / 60);
        y: parent.height - (p / max_val * parent.height);
        width: parent.width / 60 + 0.5px;
        height: p / max_val * parent.height;
        background: @linear-gradient(180deg, Palette.accent.with-alpha(0.6) 0%, Palette.accent.with-alpha(0.1) 100%);
    }

    for p[idx] in upload_points : Rectangle {
        x: (60 - upload_points.length + idx) * (parent.width / 60);
        y: parent.height - (p / max_val * parent.height);
        width: parent.width / 60 + 0.5px;
        height: p / max_val * parent.height;
        background: @linear-gradient(180deg, #ff005599 0%, #ff005522 100%);
    }
}

component MenuItem inherits Rectangle {
    in property <string> text;
    in property <string> icon;
    in property <bool> danger: false;
    callback clicked;

    height: 36px;
    border-radius: 8px;
    background: touch.has-hover ? (danger ? #ed333b.with-alpha(0.1) : Palette.foreground.with-alpha(0.05)) : transparent;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 8px;
        
        Text {
            text: root.icon;
            color: danger ? #ed333b : Palette.secondary-fg;
            font-size: 14px;
            vertical-alignment: center;
        }
        Text {
            text: root.text;
            color: danger ? #ed333b : Palette.foreground;
            font-size: 12px;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component ContextMenu inherits Rectangle {
    in property <bool> is_visible;
    in property <string> ssid;
    in property <bool> is_saved;
    in property <bool> is_connected;
    
    callback forget(string);
    callback info(string);
    callback advanced(string);
    callback closed;

    width: 180px;
    height: menu-layout.preferred-height;
    background: Palette.card-bg;
    border-radius: 12px;
    border-width: 1px;
    border-color: Palette.separator;
    drop-shadow-blur: 20px;
    drop-shadow-color: rgba(0,0,0,0.6);

    menu-layout := VerticalLayout {
        padding: 6px;
        spacing: 4px;
        
        MenuItem {
            text: "Info";
            icon: "󰋼";
            clicked => { root.info(root.ssid); root.closed(); }
        }
        
        if (root.is_saved) : MenuItem {
            text: "Advanced";
            icon: "⚙";
            clicked => { root.advanced(root.ssid); root.closed(); }
        }
        
        if (root.is_saved) : MenuItem {
            text: "Forget";
            icon: "󰆴";
            danger: true;
            clicked => { root.forget(root.ssid); root.closed(); }
        }
    }
}

component FormLabel inherits Text {
    font-size: 11px;
    color: Palette.secondary-fg;
    font-weight: 700;
}

export component AppWindow inherits Window {
    in property <[NetworkItem]> networks;
    in property <[VpnItem]> vpns;
    in property <string> status_msg: "Ready";
    in property <bool> is_connecting: false;
    in property <bool> show_settings: false;
    in property <bool> pywal_enabled: false;
    
    in property <[float]> download_history;
    in property <[float]> upload_history;
    in property <float> max_speed: 1.0;
    in property <string> current_download: "0 B/s";
    in property <string> current_upload: "0 B/s";
    in property <string> expanded_ssid: "";

    // Info & Advanced Props
    in property <string> info_content: "";
    in-out property <bool> show_info: false;
    in-out property <bool> show_advanced: false;
    in property <string> active_config_ssid: "";
    
    in-out property <bool> config_autoconnect: true;
    in-out property <int> config_priority: 0;
    in-out property <string> config_dns: "";
    in-out property <string> config_ipv4_method: "auto";
    in-out property <string> config_ipv4_address: "";
    in-out property <string> config_ipv4_gateway: "";
    in-out property <string> config_ipv6_method: "auto";
    in-out property <string> config_ipv6_address: "";
    in-out property <string> config_ipv6_gateway: "";
    in-out property <string> config_mac_address: "";
    in-out property <string> config_password: "";

    callback connect(string, string);
    callback disconnect();
    callback refresh();
    callback toggle_settings();
    callback toggle_pywal(bool);
    callback open_nmtui();
    callback expand_network(string);
    callback toggle_vpn(string, string, bool);
    callback import_vpn();
    
    callback forget_network(string);
    callback show_network_info(string);
    callback show_network_advanced(string);
    callback save_network_config(
        string, // ssid
        bool,   // autoconnect
        int,    // priority
        string, // dns
        string, // ipv4_method
        string, // ipv4_address
        string, // ipv4_gateway
        string, // ipv6_method
        string, // ipv6_address
        string, // ipv6_gateway
        string, // mac
        string  // password
    );

    title: "AuraLink";
    min-width: 400px;
    max-width: 400px;
    min-height: 647px;
    max-height: 647px;
    background: Palette.background;
    default-font-family: "JetBrainsMono Nerd Font";
    no-frame: true;
    always-on-top: true;

    property <length> context_menu_x: 0;
    property <length> context_menu_y: 0;
    in-out property <bool> show_context_menu: false;
    property <string> context_ssid: "";
    property <bool> context_is_saved: false;
    property <bool> context_is_connected: false;

    // Overlay handler
    TouchArea {
        width: 100%; height: 100%;
        visible: show_context_menu || show_info || show_advanced;
        clicked => { 
            show_context_menu = false; 
            show_info = false;
            show_advanced = false;
        }
    }

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        // Header
        HorizontalLayout {
            padding-bottom: 8px;
            VerticalLayout {
                Text {
                    text: "AURA//LINK";
                    font-size: 22px;
                    font-weight: 900;
                    color: Palette.accent;
                    letter-spacing: 2px;
                }
                Text {
                    text: "SYS.STATUS: " + status_msg;
                    font-size: 10px;
                    font-weight: 700;
                    color: Palette.secondary-fg;
                    letter-spacing: 1px;
                }
            }
            
            HorizontalLayout {
                alignment: end;
                spacing: 8px;
                
                Rectangle {
                    width: 32px;
                    height: 32px;
                    background: Palette.card-bg;
                    border-radius: 8px;
                    Text { text: "󰑐"; font-size: 16px; color: Palette.foreground; }
                    TouchArea { clicked => { refresh(); } }
                }
                Rectangle {
                    width: 32px;
                    height: 32px;
                    background: Palette.card-bg;
                    border-radius: 8px;
                    Text { text: "⚙"; font-size: 16px; color: Palette.foreground; }
                    TouchArea { clicked => { toggle_settings(); } }
                }
            }
        }

        if (show_settings) : Rectangle {
            background: Palette.card-bg;
            border-radius: 16px;
            height: 150px;
            
            VerticalLayout {
                padding: 12px;
                spacing: 12px;
                
                ThemeToggle {
                    text: "Pywal Auto-Sync";
                    checked: pywal_enabled;
                    toggled(enabled) => { toggle_pywal(enabled); }
                }

                ActionButton {
                    text: "Import VPN Config (.conf, .ovpn)";
                    clicked => { import_vpn(); }
                }

                Rectangle {
                    height: 32px;
                    background: Palette.accent.with-alpha(0.1);
                    border-radius: 8px;
                    border-width: 0;
                    HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        Text { text: "🛠 Advanced Editor (nmtui)"; font-size: 12px; color: Palette.foreground; }
                    }
                    TouchArea { clicked => { open_nmtui(); } }
                }
            }
        }

        ScrollView {
            VerticalLayout {
                spacing: 16px;
                alignment: start;

                // Wi-Fi Section
                VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: "NETWORK SIGNATURES";
                        font-size: 10px;
                        font-weight: 900;
                        color: Palette.secondary-fg;
                        letter-spacing: 2px;
                    }

                    VerticalLayout {
                        spacing: 8px;
                        for net[idx] in networks : Rectangle {
                            background: net.connected ? Palette.accent.with-alpha(0.1) : (touch.has-hover ? Palette.card-bg.brighter(10%) : Palette.card-bg);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: net.connected ? Palette.accent : (touch.has-hover ? Palette.separator.brighter(20%) : Palette.separator);
                            animate background { duration: 200ms; easing: ease-in-out; }
                            animate border-color { duration: 200ms; easing: ease-in-out; }
                            
                            touch := TouchArea {
                                clicked => {
                                    if (net.connected) {
                                        expand_network(net.ssid == expanded_ssid ? "" : net.ssid);
                                    }
                                }
                            }

                            VerticalLayout {
                                padding: 12px;
                                spacing: 8px;

                                HorizontalLayout {
                                    spacing: 16px;
                                    
                                    // 1. Icon
                                    VerticalLayout {
                                        alignment: center;
                                        width: 32px;
                                        Text {
                                            text: net.icon;
                                            font-size: 22px;
                                            color: net.icon_color;
                                            horizontal-alignment: center;
                                        }
                                    }

                                    // 2. Details
                                    VerticalLayout {
                                        alignment: center;
                                        spacing: 4px;
                                        
                                        HorizontalLayout {
                                            spacing: 8px;
                                            alignment: start;
                                            Text {
                                                text: net.ssid;
                                                font-size: 14px;
                                                font-weight: 800;
                                                color: Palette.foreground;
                                            }
                                            if (net.saved) : Text {
                                                text: "󰌆";
                                                font-size: 12px;
                                                color: Palette.accent;
                                                vertical-alignment: center;
                                            }
                                        }
                                        
                                        HorizontalLayout {
                                            spacing: 8px;
                                            alignment: start;
                                            Text {
                                                text: net.signal + "% STR";
                                                font-size: 10px;
                                                font-weight: 800;
                                                color: Palette.secondary-fg;
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: "///";
                                                font-size: 10px;
                                                color: Palette.separator;
                                                vertical-alignment: center;
                                            }
                                            if (net.security != "" && net.security != "--") : Rectangle {
                                                background: Palette.accent.with-alpha(0.15);
                                                border-radius: 4px;
                                                border-width: 1px;
                                                border-color: Palette.accent.with-alpha(0.3);
                                                HorizontalLayout {
                                                    padding-left: 6px;
                                                    padding-right: 6px;
                                                    padding-top: 2px;
                                                    padding-bottom: 2px;
                                                    Text {
                                                        text: net.security;
                                                        font-size: 9px;
                                                        font-weight: 800;
                                                        color: Palette.accent;
                                                        letter-spacing: 0.5px;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                    
                                    Rectangle {} // Flexible Spacer
                                    
                                    // 3. Actions
                                    HorizontalLayout {
                                        alignment: end;
                                        spacing: 12px;
                                        
                                        VerticalLayout {
                                            alignment: center;
                                            Rectangle {
                                                width: 24px;
                                                height: 24px;
                                                background: context-touch.has-hover ? Palette.foreground.with-alpha(0.1) : transparent;
                                                border-radius: 4px;
                                                Text { text: "󰇘"; font-size: 18px; color: Palette.foreground; }
                                                context-touch := TouchArea {
                                                    clicked => {
                                                        context_ssid = net.ssid;
                                                        context_is_saved = net.saved;
                                                        context_is_connected = net.connected;
                                                        context_menu_x = self.absolute-position.x - 140px;
                                                        context_menu_y = self.absolute-position.y + 20px;
                                                        show_context_menu = true;
                                                    }
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            alignment: center;
                                            if (net.connected) : HorizontalLayout {
                                                spacing: 12px;
                                                alignment: center;
                                                Text {
                                                    text: net.ping;
                                                    font-weight: 800;
                                                    color: Palette.accent;
                                                    vertical-alignment: center;
                                                }
                                                ActionButton {
                                                    text: "DISCONNECT";
                                                    primary: false;
                                                    danger: true;
                                                    width: 90px;
                                                    clicked => { disconnect(); }
                                                }
                                            }
                                            if (!net.connected) : ActionButton {
                                                text: "CONNECT";
                                                enabled: !is_connecting;
                                                width: 90px;
                                                clicked => { connect(net.ssid, ""); }
                                            }
                                        }
                                    }
                                }

                                if (net.ssid == expanded_ssid) : VerticalLayout {
                                    spacing: 8px;
                                    SpeedGraph {
                                        height: 140px;
                                        download_points: download_history;
                                        upload_points: upload_history;
                                        max_val: max_speed;
                                    }
                                    HorizontalLayout {
                                        spacing: 12px;
                                        Text { text: "⬇ " + current_download; color: Palette.accent; font-weight: 800; font-size: 10px; }
                                        Text { text: "⬆ " + current_upload; color: #ff0055; font-weight: 800; font-size: 10px; }
                                    }
                                }
                            }
                        }
                    }
                }

                // VPN Section
                if (vpns.length > 0) : VerticalLayout {
                    spacing: 8px;

                    VerticalLayout {
                        padding-top: 12px;
                        padding-bottom: 4px;
                        Text {
                            text: "SECURE TUNNELS";
                            font-size: 10px;
                            font-weight: 900;
                            color: Palette.secondary-fg;
                            letter-spacing: 2px;
                        }
                    }
                    
                    VerticalLayout {
                        spacing: 8px;
                        for vpn[idx] in vpns : Rectangle {
                            background: vpn-touch.has-hover ? Palette.card-bg.brighter(10%) : Palette.card-bg;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: vpn.active ? Palette.accent : (vpn-touch.has-hover ? Palette.separator.brighter(20%) : Palette.separator);
                            height: 50px;
                            animate background { duration: 200ms; easing: ease-in-out; }
                            animate border-color { duration: 200ms; easing: ease-in-out; }
                            
                            vpn-touch := TouchArea {}

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                spacing: 16px;

                                VerticalLayout {
                                    alignment: center;
                                    Text { text: "󰖂"; font-size: 20px; color: vpn.active ? Palette.accent : Palette.secondary-fg; }
                                }
                                
                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: vpn.name;
                                        font-size: 13px;
                                        font-weight: 800;
                                        color: Palette.foreground;
                                    }
                                }
                                
                                Rectangle {} // Flexible Spacer

                                HorizontalLayout {
                                    spacing: 16px;
                                    alignment: end;

                                    VerticalLayout {
                                        alignment: center;
                                        Text {
                                            text: vpn.type-name;
                                            font-size: 10px;
                                            font-weight: 800;
                                            color: Palette.secondary-fg;
                                            letter-spacing: 1px;
                                        }
                                    }
                                    VerticalLayout {
                                        alignment: center;
                                        ThemeToggle {
                                            checked: vpn.active;
                                            toggled(active) => { toggle_vpn(vpn.name, vpn.type-name, active); }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Context Menu Overlay
    if (show_context_menu) : ContextMenu {
        x: Math.min(context_menu_x, root.width - self.width - 10px);
        y: Math.min(context_menu_y, root.height - self.height - 10px);
        ssid: context_ssid;
        is_saved: context_is_saved;
        is_connected: context_is_connected;
        forget(s) => { forget_network(s); }
        info(s) => { show_network_info(s); }
        advanced(s) => { show_network_advanced(s); }
        closed => { show_context_menu = false; }
    }

    // Info Modal
    if (show_info) : Rectangle {
        x: 10px; y: 40px;
        width: root.width - 20px;
        height: root.height - 80px;
        background: Palette.card-bg;
        border-radius: 12px;
        border-width: 1px;
        border-color: Palette.separator;
        
        VerticalLayout {
            padding: 20px;
            spacing: 16px;
            Text { text: "Connection Details"; font-size: 20px; font-weight: 800; color: Palette.foreground; }
            ScrollView {
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: info_content;
                        color: Palette.foreground;
                        font-size: 14px;
                        font-family: "JetBrainsMono Nerd Font";
                        wrap: word-wrap;
                        letter-spacing: 0.5px;
                    }
                }
            }
            ActionButton {
                text: "Close";
                clicked => { show_info = false; }
            }
        }
    }

    // Advanced Config Modal
    if (show_advanced) : Rectangle {
        x: 10px; y: 40px;
        width: root.width - 20px;
        height: root.height - 80px;
        background: Palette.card-bg;
        border-radius: 12px;
        border-width: 1px;
        border-color: Palette.separator;
        
        VerticalLayout {
            padding: 16px;
            spacing: 12px;
            Text { text: "Settings: " + active_config_ssid; font-size: 16px; font-weight: 700; color: Palette.foreground; }
            
            ScrollView {
                VerticalLayout {
                    spacing: 16px;
                    
                    // General
                    VerticalLayout {
                        spacing: 8px;
                        Text { text: "GENERAL"; font-size: 10px; font-weight: 800; color: Palette.accent; }
                        CheckBox {
                            text: "Connect Automatically";
                            checked: config_autoconnect;
                            toggled => { config_autoconnect = !config_autoconnect; }
                        }
                        
                        VerticalLayout {
                            spacing: 4px;
                            FormLabel { text: "Priority (Higher = preferred)"; }
                            LineEdit {
                                text: config_priority;
                                edited(t) => { config_priority = t.to-float(); }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            FormLabel { text: "Wi-Fi Password"; }
                            LineEdit {
                                text: config_password;
                                input-type: password;
                                edited(t) => { config_password = t; }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            FormLabel { text: "Cloned MAC Address (Spoofing)"; }
                            LineEdit {
                                text: config_mac_address;
                                placeholder-text: "00:11:22:33:44:55";
                                edited(t) => { config_mac_address = t; }
                            }
                        }
                    }

                    // IPv4
                    VerticalLayout {
                        spacing: 8px;
                        Text { text: "IPv4 CONFIGURATION"; font-size: 10px; font-weight: 800; color: Palette.accent; }
                        
                        VerticalLayout {
                            spacing: 4px;
                            FormLabel { text: "Method"; }
                            LineEdit {
                                text: config_ipv4_method;
                                placeholder-text: "auto, manual, disabled";
                                edited(t) => { config_ipv4_method = t; }
                            }
                        }

                        if (config_ipv4_method == "manual") : VerticalLayout {
                            spacing: 8px;
                            VerticalLayout {
                                spacing: 4px;
                                FormLabel { text: "Address (e.g. 192.168.1.10/24)"; }
                                LineEdit {
                                    text: config_ipv4_address;
                                    edited(t) => { config_ipv4_address = t; }
                                }
                            }
                            VerticalLayout {
                                spacing: 4px;
                                FormLabel { text: "Gateway"; }
                                LineEdit {
                                    text: config_ipv4_gateway;
                                    edited(t) => { config_ipv4_gateway = t; }
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;
                            FormLabel { text: "DNS Servers (comma separated)"; }
                            LineEdit {
                                text: config_dns;
                                edited(t) => { config_dns = t; }
                            }
                        }
                    }

                    // IPv6
                    VerticalLayout {
                        spacing: 8px;
                        Text { text: "IPv6 CONFIGURATION"; font-size: 10px; font-weight: 800; color: Palette.accent; }
                        
                        VerticalLayout {
                            spacing: 4px;
                            FormLabel { text: "Method"; }
                            LineEdit {
                                text: config_ipv6_method;
                                placeholder-text: "auto, manual, ignore";
                                edited(t) => { config_ipv6_method = t; }
                            }
                        }

                        if (config_ipv6_method == "manual") : VerticalLayout {
                            spacing: 8px;
                            VerticalLayout {
                                spacing: 4px;
                                FormLabel { text: "Address"; }
                                LineEdit {
                                    text: config_ipv6_address;
                                    edited(t) => { config_ipv6_address = t; }
                                }
                            }
                            VerticalLayout {
                                spacing: 4px;
                                FormLabel { text: "Gateway"; }
                                LineEdit {
                                    text: config_ipv6_gateway;
                                    edited(t) => { config_ipv6_gateway = t; }
                                }
                            }
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 10px;
                ActionButton {
                    text: "Cancel"; primary: false;
                    clicked => { show_advanced = false; }
                }
                ActionButton {
                    text: "Save Changes";
                    clicked => {
                        save_network_config(
                            active_config_ssid, 
                            config_autoconnect, 
                            config_priority, 
                            config_dns,
                            config_ipv4_method,
                            config_ipv4_address,
                            config_ipv4_gateway,
                            config_ipv6_method,
                            config_ipv6_address,
                            config_ipv6_gateway,
                            config_mac_address,
                            config_password
                        );
                        show_advanced = false;
                    }
                }
            }
        }
    }
}
